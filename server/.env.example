NODE_ENV=production
PORT=5000
FRONTEND_URL=https://legaltypingtest.online
EXTRA_CORS_ORIGINS=https://www.legaltypingtest.online
JWT_SECRET=replace_with_openssl_rand_hex_32

# Admin
ADMIN_EMAIL=your_admin_email@example.com
# Prefer ADMIN_PASSWORD_HASH in production. Generate with the command in DEPLOYMENT.md.
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=

# Supabase / PostgreSQL - rotate any key already pasted in chat before production
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=passage-pdfs
DATABASE_URL=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Runtime mode: sqlite for current local app, postgres for future production data adapter
DATA_PROVIDER=sqlite
